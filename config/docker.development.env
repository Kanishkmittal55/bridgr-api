# Local Docker Compose — same pattern as users/config/docker.development.env.
# Services load this via env_file; override keys in docker-compose.yaml only when needed.
#
# --- PostgreSQL: connect FROM YOUR MACHINE (TablePlus, psql) ---
#   Host:     localhost
#   Port:     5433                    # compose maps 5433 -> container 5432 (see docker-compose.yaml)
#   User:     bridgr
#   Password: bridgr
#   Database: bridgr
#   SSL:      disable
# Inside other Docker services, use host `postgres` and port `5432` (values below).

ENV=development

POSTGRES_HOST=postgres
POSTGRES_PRIMARY_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bridgr
POSTGRES_PASSWORD=bridgr
POSTGRES_DB=bridgr
POSTGRES_SSL_MODE_DISABLED=true
DB_NAME=bridgr

PORT=8080
S3_URL=http://minio:9000
S3_EXTERNAL_URL=http://localhost:9000
S3_USER=minioadmin
S3_PASSWORD=minioadmin
HASSLE_SKIP_S3_BUCKET=bridgr
AWS_REGION=us-east-1
SQS_ENDPOINT=http://localstack:4566
SQS_BRIDGR_QUEUE_URL=http://localstack:4566/000000000000/bridgr-skill-gap
BRIDGR_ALL_ACCESS_API_KEY=test-all-access-key

# Radar Python gRPC (Discovery / JobSearch / PDF). In Docker Compose the service name is `radar`.
RADAR_ADDR=radar:50051

# Job discovery runs via SQS → bridgr-worker. Ensure `worker` is up and SQS_BRIDGR_QUEUE_URL is set.

# Optional: job discovery / LLM (Radar JobSearch). Uncomment and set for real calls:
OPENAI_API_KEY=
# GEMINI_API_KEY=

# LocalStack 4+ (optional): https://app.localstack.cloud/settings/auth-tokens
LOCALSTACK_AUTH_TOKEN=ls-VuNaBeYU-Jecu-TeMi-hIhU-05171630b112
