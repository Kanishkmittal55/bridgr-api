# ApplyPilot-style LLM (first set wins: GEMINI > OPENAI > LLM_URL)
# LLM_MODEL overrides the model for any provider.

# Option 1: Google Gemini
GEMINI_API_KEY=your-gemini-key

# Option 2: OpenAI
# OPENAI_API_KEY=sk-...

# Option 3: Local OpenAI-compatible (Ollama, llama.cpp, etc.)
# LLM_URL=http://localhost:11434/v1
# LLM_API_KEY=no-token
# LLM_MODEL=llama3.2